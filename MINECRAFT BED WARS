<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2D 2-Player Bed Wars Minecraft Clone</title>
    <style>
        body {
            margin: 0; padding: 0; background: #111; color: #fff;
            font-family: sans-serif; display: flex; flex-direction: column;
            align-items: center; user-select: none; overflow: hidden;
        }
        #game-container { position: relative; margin-top: 10px; }
        canvas { display: block; background: #87CEEB; border: 4px solid #333; }
        #ui-overlay {
            position: absolute; top: 10px; left: 10px; right: 10px;
            display: flex; justify-content: space-between; pointer-events: none;
        }
        .player-card { background: rgba(0, 0, 0, 0.6); padding: 8px 15px; border-radius: 5px; font-size: 14px; }
        .p1-card { border-left: 5px solid #ff4444; }
        .p2-card { border-right: 5px solid #4444ff; text-align: right; }
        #instructions { margin-top: 5px; background: #222; padding: 10px; border-radius: 5px; display: flex; gap: 20px; font-size: 12px; }
        .key { background: #444; padding: 2px 6px; border-radius: 3px; }
        #victory-screen {
            display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.85); flex-direction: column; justify-content: center; align-items: center;
        }
        #victory-text { font-size: 48px; font-weight: bold; margin-bottom: 20px; }
        #restart-btn { background: #4CAF50; color: white; border: none; padding: 10px 20px; font-size: 18px; cursor: pointer; border-radius: 5px; }
    </style>
</head>
<body>
    <h2 style="margin: 5px 0 0 0;">MINECRAFT BED WARS (2-PLAYER)</h2>
    <div id="game-container">
        <canvas id="gameCanvas" width="900" height="450"></canvas>
        <div id="ui-overlay">
            <div class="player-card p1-card">
                <strong style="color:#ff4444;">RED (P1)</strong><br>
                HP: <span id="p1-hp">100</span>% | Bed: <span id="p1-bed">ALIVE</span><br>
                Blocks: <span id="p1-blocks">10</span> | Iron: <span id="p1-iron">0</span>
            </div>
            <div class="player-card p2-card">
                <strong style="color:#4444ff;">BLUE (P2)</strong><br>
                HP: <span id="p2-hp">100</span>% | Bed: <span id="p2-bed">ALIVE</span><br>
                Blocks: <span id="p2-blocks">10</span> | Iron: <span id="p2-iron">0</span>
            </div>
        </div>
        <div id="victory-screen">
            <div id="victory-text">RED WINS!</div>
            <button id="restart-btn" onclick="resetGame()">Play Again</button>
        </div>
    </div>
    <div id="instructions">
        <div><strong style="color:#ff4444;">P1 (Red):</strong> Move: <span class="key">A</span>/<span class="key">D</span> | Jump: <span class="key">W</span> | Build: <span class="key">S</span> | Break/Attack: <span class="key">F</span></div>
        <div><strong style="color:#4444ff;">P2 (Blue):</strong> Move: <span class="key">←</span>/<span class="key">→</span> | Jump: <span class="key">↑</span> | Build: <span class="key">↓</span> | Break/Attack: <span class="key">/</span></div>
        <div><strong>Rules:</strong> Stand near center <span style="color:#ccc;font-weight:bold;">Iron Spawners</span>. Iron trades automatically for Wool Blocks at your base!</div>
    </div>
    <script>
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");
        const TILE_SIZE = 30;
        const GRID_WIDTH = canvas.width / TILE_SIZE;  
        const GRID_HEIGHT = canvas.height / TILE_SIZE; 
        const GRAVITY = 0.4;

        const BLOCKS = { AIR: 0, DIRT: 1, IRON_GEN: 2, P1_BED: 3, P2_BED: 4, RED_WOOL: 5, BLUE_WOOL: 6 };
        const COLORS = { 0: "transparent", 1: "#795548", 2: "#9e9e9e", 3: "#d32f2f", 4: "#1976d2", 5: "#ef5350", 6: "#42a5f5" };

        let grid = [];
        let p1, p2;
        let ironSpawnerTimer = 0;
        let gameOver = false;
        const keys = {};

        window.addEventListener("keydown", e => { keys[e.key.toLowerCase()] = true; });
        window.addEventListener("keyup", e => { keys[e.key.toLowerCase()] = false; });

        function initGrid() {
            grid = [];
            for (let r = 0; r < GRID_HEIGHT; r++) {
                grid[r] = [];
                for (let c = 0; c < GRID_WIDTH; c++) {
                    let type = BLOCKS.AIR;
                    if (r === 10 && c >= 1 && c <= 6) type = BLOCKS.DIRT;      // Left Island
                    if (r === 10 && c >= 23 && c <= 28) type = BLOCKS.DIRT;    // Right Island
                    if (r === 12 && c >= 12 && c <= 17) type = BLOCKS.DIRT;    // Center Forge Island
                    if (r === 11 && (c === 14 || c === 15)) type = BLOCKS.IRON_GEN; // Spawners
                    if (r === 9 && c === 2) type = BLOCKS.P1_BED;              // Red Bed
                    if (r === 9 && c === 27) type = BLOCKS.P2_BED;             // Blue Bed
                    grid[r][c] = type;
                }
            }
        }
        class Player {
            constructor(x, y, color, team) {
                this.spawnX = x; this.spawnY = y; this.x = x; this.y = y;
                this.vx = 0; this.vy = 0; this.width = 20; this.height = 28;
                this.color = color; this.team = team; this.hp = 100;
                this.blocks = 10; this.iron = 0; this.facingDir = team === 1 ? 1 : -1;
            }
            reset() { this.x = this.spawnX; this.y = this.spawnY; this.vx = 0; this.vy = 0; this.hp = 100; }
            update() {
                this.vy += GRAVITY;
                this.x += this.vx; this.collide(this.vx, 0);
                this.y += this.vy; this.collide(0, this.vy);
                if (this.y > canvas.height) this.takeDamage(100);

                // Auto Forge Trade-In: 2 Iron = 5 Blocks when at home island base
                const currentCol = Math.floor((this.x + this.width / 2) / TILE_SIZE);
                if (this.iron >= 2) {
                    if ((this.team === 1 && currentCol <= 6) || (this.team === 2 && currentCol >= 23)) {
                        this.iron -= 2; this.blocks += 5;
                    }
                }
            }
            collide(vx, vy) {
                for (let r = 0; r < GRID_HEIGHT; r++) {
                    for (let c = 0; c < GRID_WIDTH; c++) {
                        if (grid[r][c] !== BLOCKS.AIR) {
                            let bx = c * TILE_SIZE, by = r * TILE_SIZE;
                            if (this.x < bx + TILE_SIZE && this.x + this.width > bx && this.y < by + TILE_SIZE && this.y + this.height > by) {
                                if (vx > 0) this.x = bx - this.width;
                                if (vx < 0) this.x = bx + TILE_SIZE;
                                if (vy > 0) { this.y = by - this.height; this.vy = 0; }
                                if (vy < 0) { this.y = by + TILE_SIZE; this.vy = 0; }
                            }
                        }
                    }
                }
            }
            takeDamage(amount) {
                this.hp -= amount;
                if (this.hp <= 0) {
                    if (isBedAlive(this.team)) { this.reset(); } 
                    else { this.hp = 0; endGame(this.team === 1 ? 2 : 1); }
                }
            }
            draw() {
                ctx.fillStyle = this.color; ctx.fillRect(this.x, this.y, this.width, this.height);
                ctx.fillStyle = "#fff";     ctx.fillRect(this.x + (this.facingDir === 1 ? this.width - 6 : 2), this.y + 4, 4, 4);
            }
        }
        function isBedAlive(team) {
            let bedBlock = team === 1 ? BLOCKS.P1_BED : BLOCKS.P2_BED;
            return grid.some(row => row.includes(bedBlock));
        }
        function handleInput() {
            if (gameOver) return;
            p1.vx = 0;
            if (keys['a']) { p1.vx = -3; p1.facingDir = -1; }
            if (keys['d']) { p1.vx = 3; p1.facingDir = 1; }
            if (keys['w'] && p1.vy === 0) p1.vy = -7.5;

            p2.vx = 0;
            if (keys['arrowleft']) { p2.vx = -3; p2.facingDir = -1; }
            if (keys['arrowright']) { p2.vx = 3; p2.facingDir = 1; }
            if (keys['arrowup'] && p2.vy === 0) p2.vy = -7.5;
        }

        window.addEventListener("keydown", e => {
            if (gameOver) return; const k = e.key.toLowerCase();
            if (k === 's') tryPlaceBlock(p1, BLOCKS.RED_WOOL);
            if (k === 'f') tryBreakOrAttack(p1, p2);
            if (k === 'arrowdown') tryPlaceBlock(p2, BLOCKS.BLUE_WOOL);
            if (k === '/') tryBreakOrAttack(p2, p1);
        });

        function tryPlaceBlock(player, blockType) {
            if (player.blocks <= 0) return;
            let targetCol = Math.floor((player.x + (player.facingDir === 1 ? player.width + 5 : -15)) / TILE_SIZE);
            let targetRow = Math.floor((player.y + player.height / 2) / TILE_SIZE);
            if (targetCol >= 0 && targetCol < GRID_WIDTH && targetRow >= 0 && targetRow < GRID_HEIGHT) {
                if (grid[targetRow][targetCol] === BLOCKS.AIR) { grid[targetRow][targetCol] = blockType; player.blocks--; }
            }
        }

        function tryBreakOrAttack(attacker, opponent) {
            let targetCol = Math.floor((attacker.x + (attacker.facingDir === 1 ? attacker.width + 12 : -20)) / TILE_SIZE);
            let targetRow = Math.floor((attacker.y + attacker.height / 2) / TILE_SIZE);
            let dist = Math.hypot((attacker.x + attacker.width/2) - (opponent.x + opponent.width/2), (attacker.y + attacker.height/2) - (opponent.y + opponent.height/2));
            if (dist < 45) { opponent.takeDamage(25); opponent.vx += attacker.facingDir * 5; opponent.vy -= 3; return; }
            if (targetCol >= 0 && targetCol < GRID_WIDTH && targetRow >= 0 && targetRow < GRID_HEIGHT) {
                let block = grid[targetRow][targetCol];
                if (block !== BLOCKS.AIR && block !== BLOCKS.IRON_GEN && block !== BLOCKS.DIRT) grid[targetRow][targetCol] = BLOCKS.AIR;
            }
        }

        function updateSpawners() {
            ironSpawnerTimer++;
            if (ironSpawnerTimer >= 90) {
                ironSpawnerTimer = 0;
                for (let r = 0; r < GRID_HEIGHT; r++) {
                    for (let c = 0; c < GRID_WIDTH; c++) {
                        if (grid[r][c] === BLOCKS.IRON_GEN) {
                            let bx = c * TILE_SIZE + TILE_SIZE/2, by = r * TILE_SIZE + TILE_SIZE/2;
                            [p1, p2].forEach(p => { if (Math.hypot((p.x+p.width/2)-bx, (p.y+p.height/2)-by) < TILE_SIZE*2.5) p.iron++; });
                        }
                    }
                }
            }
        }
        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            for (let r = 0; r < GRID_HEIGHT; r++) {
                for (let c = 0; c < GRID_WIDTH; c++) {
                    let block = grid[r][c];
                    if (block !== BLOCKS.AIR) {
                        ctx.fillStyle = COLORS[block]; ctx.fillRect(c * TILE_SIZE, r * TILE_SIZE, TILE_SIZE, TILE_SIZE);
                        ctx.strokeStyle = "rgba(0,0,0,0.15)"; ctx.strokeRect(c * TILE_SIZE, r * TILE_SIZE, TILE_SIZE, TILE_SIZE);
                        if (block === BLOCKS.IRON_GEN) { ctx.fillStyle = "#fff"; ctx.fillRect(c * TILE_SIZE + 10, r * TILE_SIZE + 10, 10, 10); }
                        if (block === BLOCKS.P1_BED || block === BLOCKS.P2_BED) { ctx.fillStyle = "#fff"; ctx.fillRect(c * TILE_SIZE + 4, r * TILE_SIZE + 15, 22, 8); }
                    }
                }
            }
            p1.draw(); p2.draw();
            document.getElementById("p1-hp").innerText = p1.hp;
            document.getElementById("p1-bed").innerText = isBedAlive(1) ? "ALIVE" : "DESTROYED";
            document.getElementById("p1-blocks").innerText = p1.blocks; document.getElementById("p1-iron").innerText = p1.iron;
            document.getElementById("p2-hp").innerText = p2.hp;
            document.getElementById("p2-bed").innerText = isBedAlive(2) ? "ALIVE" : "DESTROYED";
            document.getElementById("p2-blocks").innerText = p2.blocks; document.getElementById("p2-iron").innerText = p2.iron;
        }

        function gameLoop() { handleInput(); p1.update(); p2.update(); updateSpawners(); draw(); requestAnimationFrame(gameLoop); }
        function endGame(winner) {
            gameOver = true; const screen = document.getElementById("victory-screen");
            const text = document.getElementById("victory-text");
            text.innerText = winner === 1 ? "RED TEAM WINS!" : "BLUE TEAM WINS!";
            text.style.color = winner === 1 ? "#ff4444" : "#4444ff"; screen.style.display = "flex";
        }
        function resetGame() {
            document.getElementById("victory-screen").style.display = "none";
            gameOver = false; initGrid();
            p1 = new Player(60, 200, "#ff4444", 1); p2 = new Player(820, 200, "#4444ff", 2);
        }
        resetGame(); gameLoop();
    </script>
</body>
