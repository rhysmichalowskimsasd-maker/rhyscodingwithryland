                // Visual Indicator for Armor Tiers
                if (this.armorTier === 1) { ctx.strokeStyle = "#aaaaaa"; ctx.lineWidth = 2; ctx.strokeRect(this.x, this.y, this.width, this.height); }
                if (this.armorTier === 2) { ctx.strokeStyle = "#00e5ff"; ctx.lineWidth = 2; ctx.strokeRect(this.x, this.y, this.width, this.height); }
            }
        }
        function isBedAlive(team) {
            let b = team === 1 ? BLOCKS.P1_BED : BLOCKS.P2_BED;
            return grid.some(r => r.includes(b));
        }
        function handleInput() {
            if (gameOver) return;
            p1.vx = 0;
            if (keys['a']) { p1.vx = -3; p1.facingDir = -1; }
            if (keys['d']) { p1.vx = 3; p1.facingDir = 1; }
            if (keys['w'] && p1.vy === 0) p1.vy = -7.5;

            p2.vx = 0;
            if (keys['arrowleft']) { p2.vx = -3; p2.facingDir = -1; }
            if (keys['arrowright']) { p2.vx = 3; p2.facingDir = 1; }
            if (keys['arrowup'] && p2.vy === 0) p2.vy = -7.5;
        }

        window.addEventListener("keydown", e => {
            if (gameOver) return; const k = e.key.toLowerCase();
            // P1 Commands
            if (k === 's') tryPlaceBlock(p1, BLOCKS.RED_WOOL);
            if (k === 'q') tryDeployTNT(p1);
            if (k === 'f') tryBreakOrAttack(p1, p2);
            
            // P2 Commands
            if (k === 'arrowdown') tryPlaceBlock(p2, BLOCKS.BLUE_WOOL);
            if (k === 'm') tryDeployTNT(p2);
            if (k === '/') tryBreakOrAttack(p2, p1);
        });

        function tryPlaceBlock(player, blockType) {
            if (player.blocks <= 0) return;
            let targetCol = Math.floor((player.x + (player.facingDir === 1 ? player.width + 5 : -15)) / TILE_SIZE);
            let targetRow = Math.floor((player.y + player.height / 2) / TILE_SIZE);
            if (targetCol >= 0 && targetCol < GRID_WIDTH && targetRow >= 0 && targetRow < GRID_HEIGHT) {
                if (grid[targetRow][targetCol] === BLOCKS.AIR) { grid[targetRow][targetCol] = blockType; player.blocks--; }
            }
        }
        function tryDeployTNT(player) {
            if (player.tntCount <= 0) return;
            let targetCol = Math.floor((player.x + (player.facingDir === 1 ? player.width + 5 : -15)) / TILE_SIZE);
            let targetRow = Math.floor((player.y + player.height / 2) / TILE_SIZE);
            if (targetCol >= 0 && targetCol < GRID_WIDTH && targetRow >= 0 && targetRow < GRID_HEIGHT) {
                if (grid[targetRow][targetCol] === BLOCKS.AIR) {
                    grid[targetRow][targetCol] = BLOCKS.TNT; player.tntCount--;
                    setTimeout(() => detonateTNT(targetRow, targetCol), 2000); // 2-second fuse timer
                }
            }
        }

        function detonateTNT(row, col) {
            if (grid[row][col] !== BLOCKS.TNT) return;
            grid[row][col] = BLOCKS.AIR;
            tntExplosions.push({ x: col * TILE_SIZE + 15, y: row * TILE_SIZE + 15, radius: 45, timer: 15 });
            
            // Calculate structural environment blast damage
            let blastRadiusBlocks = 2;
            for (let r = row - blastRadiusBlocks; r <= row + blastRadiusBlocks; r++) {
                for (let c = col - blastRadiusBlocks; c <= col + blastRadiusBlocks; c++) {
                    if (r >= 0 && r < GRID_HEIGHT && c >= 0 && c < GRID_WIDTH) {
                        let targetBlock = grid[r][c];
                        // Blow up ONLY user bridges (Red and Blue wool)
                        if (targetBlock === BLOCKS.RED_WOOL || targetBlock === BLOCKS.BLUE_WOOL) { grid[r][c] = BLOCKS.AIR; }
                    }
                }
            }
            // Deal damage to nearby players caught in the blast radius
            let bx = col * TILE_SIZE + 15, by = row * TILE_SIZE + 15;
            [p1, p2].forEach(p => { if (Math.hypot((p.x + p.width/2) - bx, (p.y + p.height/2) - by) < 70) p.takeDamage(40); });
        }

        function updateSpawners() {
            ironSpawnerTimer++; diamondSpawnerTimer++;
            // Iron Spawning Logic
            if (ironSpawnerTimer >= 90) {
                ironSpawnerTimer = 0;
                for (let r = 0; r < GRID_HEIGHT; r++) {
                    for (let c = 0; c < GRID_WIDTH; c++) {
                        if (grid[r][c] === BLOCKS.IRON_GEN) {
                            let bx = c * TILE_SIZE + 15, by = r * TILE_SIZE + 15;
                            [p1, p2].forEach(p => { if (Math.hypot((p.x+p.width/2)-bx, (p.y+p.height/2)-by) < TILE_SIZE*2.5) p.iron++; });
                        }
                    }
                }
            }
            // Diamond Spawning Logic
            if (diamondSpawnerTimer >= 220) {
                diamondSpawnerTimer = 0;
                for (let r = 0; r < GRID_HEIGHT; r++) {
                    for (let c = 0; c < GRID_WIDTH; c++) {
                        if (grid[r][c] === BLOCKS.DIAMOND_GEN) {
                            let bx = c * TILE_SIZE + 15, by = r * TILE_SIZE + 15;
                            [p1, p2].forEach(p => { if (Math.hypot((p.x+p.width/2)-bx, (p.y+p.height/2)-by) < TILE_SIZE*2.5) p.diamonds++; });
                        }
                    }
                }
            }
        }
        function tryBreakOrAttack(attacker, opponent) {
            let targetCol = Math.floor((attacker.x + (attacker.facingDir === 1 ? attacker.width + 12 : -20)) / TILE_SIZE);
            let targetRow = Math.floor((attacker.y + attacker.height / 2) / TILE_SIZE);
            let dist = Math.hypot((attacker.x + attacker.width/2) - (opponent.x + opponent.width/2), (attacker.y + attacker.height/2) - (opponent.y + opponent.height/2));
            
            if (dist < 45) { 
                let baseDmg = attacker.swordTier === 0 ? 15 : (attacker.swordTier === 1 ? 30 : 48);
                opponent.takeDamage(baseDmg); 
                opponent.vx += attacker.facingDir * (5 + attacker.swordTier * 2); opponent.vy -= 2.5; 
                return; 
            }
            if (targetCol >= 0 && targetCol < GRID_WIDTH && targetRow >= 0 && targetRow < GRID_HEIGHT) {
                let block = grid[targetRow][targetCol];
                if (block !== BLOCKS.AIR && block !== BLOCKS.IRON_GEN && block !== BLOCKS.DIAMOND_GEN && block !== BLOCKS.DIRT) {
                    grid[targetRow][targetCol] = BLOCKS.AIR;
                }
            }
        }

        function draw() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            for (let r = 0; r < GRID_HEIGHT; r++) {
                for (let c = 0; c < GRID_WIDTH; c++) {
                    let block = grid[r][c];
                    if (block !== BLOCKS.AIR) {
                        ctx.fillStyle = COLORS[block]; ctx.fillRect(c * TILE_SIZE, r * TILE_SIZE, TILE_SIZE, TILE_SIZE);
                        ctx.strokeStyle = "rgba(0,0,0,0.12)"; ctx.strokeRect(c * TILE_SIZE, r * TILE_SIZE, TILE_SIZE, TILE_SIZE);
                        if (block === BLOCKS.IRON_GEN) { ctx.fillStyle = "#fff"; ctx.fillRect(c * TILE_SIZE + 10, r * TILE_SIZE + 10, 10, 10); }
                        if (block === BLOCKS.DIAMOND_GEN) { ctx.fillStyle = "#e5fffa"; ctx.fillRect(c * TILE_SIZE + 8, r * TILE_SIZE + 8, 14, 14); }
                        if (block === BLOCKS.P1_BED || block === BLOCKS.P2_BED) { ctx.fillStyle = "#fff"; ctx.fillRect(c * TILE_SIZE + 4, r * TILE_SIZE + 16, 22, 8); }
                    }
                }
            }
            p1.draw(); p2.draw();
            
            // Draw explosion rings
            for (let i = tntExplosions.length - 1; i >= 0; i--) {
                let exp = tntExplosions[i]; ctx.fillStyle = "rgba(255,100,0,0.4)";
                ctx.beginPath(); ctx.arc(exp.x, exp.y, exp.radius, 0, Math.PI*2); ctx.fill();
                exp.timer--; if (exp.timer <= 0) tntExplosions.splice(i, 1);
            }
            updateLabels();
        }

        function updateLabels() {
            const swords = ["Wood", "Stone (4 Iron)", "Diamond MAX"];
            const armors = ["None", "Chain (6 Iron)", "Diamond MAX"];
            
            document.getElementById("p1-hp").innerText = p1.hp;
            document.getElementById("p1-bed").innerText = isBedAlive(1) ? "ALIVE" : "DESTROYED";
            document.getElementById("p1-blocks").innerText = p1.blocks;
            document.getElementById("p1-iron").innerText = p1.iron;
            document.getElementById("p1-dia").innerText = p1.diamonds;
            document.getElementById("p1-tnt").innerText = p1.tntCount;
            document.getElementById("p1-sword").innerText = swords[p1.swordTier];
            document.getElementById("p1-armor").innerText = armors[p1.armorTier];

            document.getElementById("p2-hp").innerText = p2.hp;
            document.getElementById("p2-bed").innerText = isBedAlive(2) ? "ALIVE" : "DESTROYED";
            document.getElementById("p2-blocks").innerText = p2.blocks;
            document.getElementById("p2-iron").innerText = p2.iron;
            document.getElementById("p2-dia").innerText = p2.diamonds;
            document.getElementById("p2-tnt").innerText = p2.tntCount;
            document.getElementById("p2-sword").innerText = swords[p2.swordTier];
            document.getElementById("p2-armor").innerText = armors[p2.armorTier];
        }

        function buyItem(team, type) {
            if (gameOver) return; let p = team === 1 ? p1 : p2;
            if (type === 'sword' && p.iron >= 4 && p.swordTier === 0) { p.iron -= 4; p.swordTier = 1; }
            if (type === 'armor' && p.iron >= 6 && p.armorTier === 0) { p.iron -= 6; p.armorTier = 1; }
            if (type === 'tnt' && p.iron >= 3) { p.iron -= 3; p.tntCount++; }
            if (type === 'd_sword' && p.diamonds >= 2 && p.swordTier === 1) { p.diamonds -= 2; p.swordTier = 2; }
            if (type === 'd_armor' && p.diamonds >= 3 && p.armorTier === 1) { p.diamonds -= 3; p.armorTier = 2; }
        }

        function gameLoop() { handleInput(); p1.update(); p2.update(); updateSpawners(); draw(); requestAnimationFrame(gameLoop); }
        function endGame(w) {
            gameOver = true; const s = document.getElementById("victory-screen"); const t = document.getElementById("victory-text");
            t.innerText = w === 1 ? "RED TEAM WINS!" : "BLUE TEAM WINS!"; t.style.color = w === 1 ? "#ff4444" : "#4444ff"; s.style.display = "flex";
        }
        function resetGame() { document.getElementById("victory-screen").style.display = "none"; gameOver = false; initGrid(); p1 = new Player(60, 200, "#ff4444", 1); p2 = new Player(820, 200, "#4444ff", 2); }
        resetGame(); gameLoop();
    </script>
</body>
